{
  "name": "flobro-website",
  "version": "1.0.0",
  "private": true,
  "description": "The flobro.app website: static HTML/CSS/JS, no build step, hosted on GitHub Pages.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepare": "node -e \"try{require('child_process').execSync('git config core.hooksPath .githooks');require('fs').readdirSync('.githooks').forEach(f=>require('fs').chmodSync('.githooks/'+f,0o755))}catch(e){}\"",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "i18n": "node scripts/generate-locale-pages.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3"
  }
}
